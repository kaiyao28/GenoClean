/*
================================================================================
  Genetic QC Pipeline — Main Configuration
================================================================================
  All default thresholds live here. NEVER hard-code thresholds inside process
  scripts — always reference params.* so researchers can override at runtime:

    nextflow run snp_array_qc/main.nf --sample_missingness 0.05
    nextflow run snp_array_qc/main.nf -params-file my_params.yml
================================================================================
*/

nextflow.enable.dsl = 2

params {

    // ── Output ────────────────────────────────────────────────────────────────
    outdir            = "results"
    publish_dir_mode  = "copy"      // copy | symlink | link | move
    keep_intermediate = false       // retain per-step PLINK/BAM files when true
    docker_image      = "ghcr.io/kaiyao28/genetic-qc:1.0"

    // ── Phase-level switches ──────────────────────────────────────────────────
    // Variant-level QC (can run per-chromosome in parallel).
    run_variant_qc = true
    // Sample-level QC (genome-wide context required — see sample_qc_scope).
    run_sample_qc  = true

    // Chromosomes to process. Accepts ranges ("1-22"), single values ("22"),
    // or comma-separated lists ("1,2,22"). Prefix "chr" is handled automatically.
    // Used for per-chromosome variant QC parallelism in the WGS/WES pipeline.
    chroms = "1-22"

    // Sample QC scope guard. Controls whether sample-level QC runs and how
    // results are labelled.
    //   auto        — genome_wide if all autosomes present, provisional otherwise
    //   genome_wide — force-run and mark as final
    //   provisional — run but flag results as not suitable for final filtering
    //   skip        — skip all sample-level QC modules
    sample_qc_scope = "auto"

    // ── Module on/off switches — set false to silence a QC step ──────────────
    // SNP array
    run_duplicate_check      = true
    run_sample_missingness   = true
    run_variant_missingness  = true
    run_sex_check            = true
    run_heterozygosity       = true
    run_relatedness          = true
    run_ancestry_pca         = true
    run_hwe                  = true
    run_maf_filter           = true

    // WGS / WES
    run_fastqc                = true
    run_alignment_metrics     = true
    run_duplicate_metrics     = true
    run_coverage_qc           = true
    run_contamination         = true
    run_sex_check_wgs         = true
    run_variant_calling_qc    = true
    run_variant_filtering     = true
    run_genotype_filter       = true
    run_sample_variant_counts = true
    run_relatedness_wgs       = true
    run_ancestry_pca_wgs      = true

    // Shared
    run_final_report = true

    // ── SNP array input ───────────────────────────────────────────────────────
    bfile           = null   // PLINK binary prefix (no extension)
    pheno           = null   // optional phenotype / covariate TSV
    reference_panel = null   // optional reference panel prefix for ancestry PCA
    sample_metadata = null   // optional metadata: reported sex, batch, centre

    // ── SNP array QC thresholds ───────────────────────────────────────────────
    // Remove samples with more than sample_missingness fraction missing genotypes.
    // Anderson et al. 2010 recommend 0.02 (2%) as a conservative starting point.
    sample_missingness = 0.02

    // Remove variants with more than variant_missingness fraction missing calls.
    // A two-pass strategy (generous first, strict second) is common in practice.
    variant_missingness = 0.02

    // HWE p-value threshold. Variants departing from Hardy-Weinberg equilibrium
    // in controls may indicate genotyping error. 1e-6 is standard for GWAS.
    hwe_p = 1e-6

    // Remove variants with MAF below this. 0.01 is typical for common-variant GWAS;
    // lower the threshold for rare-variant analyses.
    maf = 0.01

    // Heterozygosity outliers: samples > ±heterozygosity_sd SD from the mean
    // may reflect DNA quality problems, contamination, or sample swaps.
    heterozygosity_sd = 3

    // PI_HAT threshold for relatedness. 0.1875 sits between 2nd-degree (0.25)
    // and 3rd-degree (0.125) relatives, capturing up to 2nd-degree pairs.
    relatedness_pi_hat = 0.1875

    // X-chromosome F-statistic (inbreeding coefficient) cutoffs for sex check.
    // Females typically F < 0.2; males typically F > 0.8.
    sex_check_f_lower_female = 0.2
    sex_check_f_upper_male   = 0.8

    // Ancestry outlier detection: samples > ±pca_outlier_sd SD along any PC
    // are flagged as potential ancestry outliers.
    pca_outlier_sd = 6

    // LD pruning parameters used before PCA and relatedness calculation.
    // Window 200 kb, step 50 variants, r² threshold 0.2 is a common choice.
    ld_window = 200
    ld_step   = 50
    ld_r2     = 0.2
    n_pcs     = 20     // number of principal components to compute

    // ── WGS / WES input ───────────────────────────────────────────────────────
    input_type       = "bam"   // fastq | bam | cram | vcf
    samplesheet      = null    // CSV with columns: sample, file1[, file2]
    reference_fasta  = null    // reference genome FASTA (with .fai index)
    target_intervals = null    // BED file of capture targets (mandatory for WES)
    gene_bed         = null    // optional per-gene coverage BED
    mode             = "wes"   // wes | wgs

    // ── WGS / WES QC thresholds ───────────────────────────────────────────────
    // WGS: minimum acceptable mean genome-wide depth.
    min_mean_depth_wgs = 20

    // WES: minimum acceptable mean on-target depth.
    min_mean_depth_wes = 30

    // Fraction of target bases with ≥20x coverage. gnomAD uses similar metrics
    // as a primary sample-level QC filter.
    min_target_20x_fraction = 0.80

    // Fraction of bases/targets covered at ≥10x.
    min_10x_fraction = 0.90

    // Maximum cross-sample contamination estimated by VerifyBamID2.
    // gnomAD v4 uses a 3% threshold; lower thresholds suit discovery studies.
    max_contamination = 0.03

    // PCR duplicate rate limit. Higher values are common in WES with tight
    // capture kits, but >20% warrants investigation.
    max_duplication_rate = 0.20

    // Minimum fraction of genotypes called per sample after genotype filtering.
    min_call_rate = 0.95

    // Per-genotype minimum quality score and depth.
    // GQ ≥ 20 and DP ≥ 10 are GATK Best Practices baseline hard-filter values.
    min_gq = 20
    min_dp = 10

    // Site-level minimum QUAL score. GATK recommends ≥ 30 in hard-filter mode.
    variant_qual = 30

    // GATK hard-filter thresholds — SNPs
    // (QualByDepth, FisherStrand, MappingQuality, etc.)
    snp_qd               = 2.0
    snp_fs               = 60.0
    snp_mq               = 40.0
    snp_mqrank_sum       = -12.5
    snp_readpos_rank_sum = -8.0

    // GATK hard-filter thresholds — indels
    indel_qd               = 2.0
    indel_fs               = 200.0
    indel_readpos_rank_sum = -20.0

    // Variant filtering strategy: "hard_filter" or "vqsr".
    // VQSR requires a large cohort and training resources; use hard_filter
    // for small WES cohorts or when training data are unavailable.
    variant_filter_method = "hard_filter"

    // ── PCA variant selection (WGS/WES only) ─────────────────────────────────
    // These params control the PCA_VARIANT_SELECTION step that runs before PCA
    // in the WGS/WES pipeline. They do NOT apply to the SNP array pipeline
    // (arrays already genotype common variants and need no separate selection).
    //
    // pca_maf: minimum MAF for variants used in PCA.
    //   Rare variants distort PCA toward rare-variant structure; 0.05 is standard.
    pca_maf                 = 0.05

    // pca_variant_missingness: maximum fraction of samples missing per site.
    //   Sites with high missingness produce unreliable PC projections.
    pca_variant_missingness = 0.01

    // pca_use_snps_only: exclude indels from PCA (recommended — indel depth
    //   estimation is less reliable than SNP genotype quality).
    pca_use_snps_only       = true

    // pca_autosomes_only: restrict to autosomes (recommended for ancestry PCA).
    //   chrX deviates from Hardy-Weinberg in females and can distort PCs.
    pca_autosomes_only      = true

    // VQSR training resource VCFs (only used when variant_filter_method = "vqsr")
    vqsr_hapmap = null
    vqsr_omni   = null
    vqsr_1000g  = null
    vqsr_dbsnp  = null

    // ── Resource caps ─────────────────────────────────────────────────────────
    max_memory = "128.GB"
    max_cpus   = 16
    max_time   = "240.h"
}

// Include per-environment resource allocations
includeConfig 'conf/base.config'

// ── Execution profiles ────────────────────────────────────────────────────────
// Profiles can be combined with a comma:
//   -profile slurm,singularity      # HPC with Singularity containers
//   -profile docker                  # local with Docker
//   -profile conda                   # local with Mamba environment
//   -profile slurm,conda             # HPC with Mamba environment
//
// Container setup:
//   Docker    : default image is params.docker_image
//               override with --docker_image genetic-qc:1.0 for a local build
//   Singularity: apptainer build containers/genetic-qc.sif docker-daemon://genetic-qc:1.0
//   Conda     : mamba env create -f containers/environment.yml
profiles {

    // ── No containers — tools must be on PATH ────────────────────────────────
    standard {
        process.executor = 'local'
    }

    // ── Docker (local machine / cloud) ───────────────────────────────────────
    // Uses params.docker_image. Override with --docker_image for local builds.
    docker {
        includeConfig 'conf/docker.config'
        singularity.enabled = false
        conda.enabled       = false
    }

    // ── Singularity / Apptainer (HPC clusters) ───────────────────────────────
    // Build SIF first: apptainer build containers/genetic-qc.sif docker-daemon://genetic-qc:1.0
    singularity {
        includeConfig 'conf/singularity.config'
        docker.enabled = false
        conda.enabled  = false
    }

    // ── Conda / Mamba (local development, no container daemon) ───────────────
    // Create env first: mamba env create -f containers/environment.yml
    conda {
        includeConfig 'conf/conda.config'
        docker.enabled      = false
        singularity.enabled = false
    }

    // ── SLURM cluster ─────────────────────────────────────────────────────────
    // Combine with a container profile: -profile slurm,singularity
    // Edit queue and account to match your cluster.
    slurm {
        process.executor       = 'slurm'
        process.queue          = 'normal'
        process.clusterOptions = '--account=myproject'
        // Increase retry attempts for transient cluster failures
        process.errorStrategy  = { task.exitStatus in [143,137,104,134,139] ? 'retry' : 'finish' }
        process.maxRetries     = 3
    }

    // ── LSF cluster ──────────────────────────────────────────────────────────
    lsf {
        process.executor = 'lsf'
        process.queue    = 'normal'
    }

    // ── AWS Batch ─────────────────────────────────────────────────────────────
    awsbatch {
        process.executor  = 'awsbatch'
        process.queue     = 'default'
        aws.region        = 'eu-west-1'
        aws.batch.cliPath = '/home/ec2-user/miniconda/bin/aws'
    }
}

// ── Pipeline lifecycle messages ───────────────────────────────────────────────
workflow.onComplete {
    log.info """
    ================================================================
    Genetic QC Pipeline — ${workflow.success ? 'COMPLETED' : 'FAILED'}
    ================================================================
    Run name  : ${workflow.runName}
    Start     : ${workflow.start}
    Duration  : ${workflow.duration}
    Output    : ${params.outdir}
    ================================================================
    """.stripIndent()
}

workflow.onError {
    log.error "Pipeline failed. Check logs in ${params.outdir}/logs/"
}
