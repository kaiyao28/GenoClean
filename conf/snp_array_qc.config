/*
================================================================================
  snp_array_qc.config — SNP Array Pipeline Defaults
================================================================================
  Override any of these values on the command line or in a params YAML file.
  This file is included automatically when running snp_array_qc/main.nf.
================================================================================
*/

params {

    // ── Input ─────────────────────────────────────────────────────────────────
    bfile           = null   // PLINK binary file prefix (without .bed/.bim/.fam)
    pheno           = null   // tab-separated phenotype file (FID IID PHENO ...)
    reference_panel = null   // 1000 Genomes or similar prefix for ancestry PCA
    sample_metadata = null   // sample sheet: FID IID SEX BATCH CENTRE ARRAY

    // ── Phase-level switches ──────────────────────────────────────────────────
    run_variant_qc  = true
    run_sample_qc   = true
    chroms          = "1-22"    // used for chromosome-parallel mode (optional for arrays)
    sample_qc_scope = "auto"   // auto | genome_wide | provisional | skip

    // ── Step switches ─────────────────────────────────────────────────────────
    run_duplicate_check     = true
    run_sample_missingness  = true
    run_variant_missingness = true
    run_sex_check           = true
    run_heterozygosity      = true
    run_relatedness         = true
    run_ancestry_pca        = true
    run_hwe                 = true
    run_maf_filter          = true
    run_final_report        = true

    // ── Thresholds ────────────────────────────────────────────────────────────
    //    All of these can be overridden per-run without editing this file.
    sample_missingness       = 0.02
    variant_missingness      = 0.02
    hwe_p                    = 1e-6
    maf                      = 0.01
    heterozygosity_sd        = 3
    relatedness_pi_hat       = 0.1875
    sex_check_f_lower_female = 0.2
    sex_check_f_upper_male   = 0.8
    pca_outlier_sd           = 6
    ld_window                = 200
    ld_step                  = 50
    ld_r2                    = 0.2
    n_pcs                    = 20

    // ── Output ────────────────────────────────────────────────────────────────
    outdir            = "results/snp_array_qc"
    publish_dir_mode  = "copy"
    keep_intermediate = false
}
