/*
================================================================================
  docker.config
================================================================================
  Activated with: -profile docker
  Requires Docker daemon to be running locally.

  To build the image first:
    docker build -t genetic-qc:1.0 -f containers/Dockerfile .

  To use a pre-built image from a registry (faster):
    Set the container line below to the registry URI, e.g.:
      container = 'ghcr.io/yourname/genetic-qc:1.0'
================================================================================
*/

docker {
    enabled      = true
    runOptions   = '-u $(id -u):$(id -g)'  // run as current user, not root
    // Remove the line above if your pipeline needs to write to read-only paths
}

// Mount the working directory automatically (Nextflow does this by default,
// but explicit runOptions can override it — keep enabled)
process {
    container = 'genetic-qc:1.0'
}
