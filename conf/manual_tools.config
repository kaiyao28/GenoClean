/*
================================================================================
  manual_tools.config — Tool paths for HPC without conda/Docker/Singularity
================================================================================
  Use this when tools were installed manually via setup_hpc_manual.sh.

  Activate via the  manual_paths  profile (defined in nextflow.config):
    -profile manual_paths               # local execution
    -profile slurm,manual_paths         # SLURM with manual tools
    -profile lsf,manual_paths           # LSF with manual tools

  The tool directory is resolved in this order:
    1. --tool_dir /path/to/tools        (nextflow CLI flag)
    2. GENETIC_QC_TOOL_DIR env variable
    3. ~/genetic_qc_tools               (default set by setup_hpc_manual.sh)

  You do NOT need to edit this file — just set the env variable or flag.
================================================================================
*/

params {
    tool_dir = System.getenv('GENETIC_QC_TOOL_DIR') ?: "${System.getenv('HOME')}/genetic_qc_tools"
}

process {
    // Prepend the tool bin/ directory to PATH for every process.
    // This runs on each compute node before the process script executes,
    // so it works correctly with SLURM, LSF, and other schedulers.
    beforeScript = """
        export PATH="${params.tool_dir}/bin:${params.tool_dir}/lib:\$PATH"
        export LD_LIBRARY_PATH="${params.tool_dir}/lib:\${LD_LIBRARY_PATH:-}"
        export VERIFYBAMID2_SVD_PREFIX="${params.tool_dir}/verifybamid2/resource/1000g.phase3.100k.b38.vcf.gz.dat"
    """
}
