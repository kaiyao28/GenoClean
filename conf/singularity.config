/*
================================================================================
  singularity.config
================================================================================
  Activated with: -profile singularity  (or -profile slurm,singularity)
  Recommended for HPC clusters where Docker is not permitted.

  Build the SIF once from the published Docker image:
    apptainer build containers/genetic-qc.sif docker://ghcr.io/kaiyao28/genetic-qc:1.0

  Or, if you built a local Docker image yourself:
    apptainer build containers/genetic-qc.sif docker-daemon://genetic-qc:1.0

  The cacheDir below tells Nextflow/Apptainer where to cache pulled images.
  Set it to a directory on shared storage so it is accessible from all nodes.
================================================================================
*/

singularity {
    enabled    = true
    autoMounts = true    // automatically bind-mount working directory and /tmp
    // cacheDir = '/path/to/shared/singularity_cache'  // recommended on HPC
}

process {
    // Use the locally built SIF.
    // If the SIF lives in a shared directory, replace with the absolute path.
    container = "${projectDir}/containers/genetic-qc.sif"
}
