/*
================================================================================
  conda.config
================================================================================
  Activated with: -profile conda
  Useful for local development or systems without Docker/Singularity.

  Create the environment first:
    mamba env create -f containers/environment.yml
    # (environment name is "genetic_qc" as defined in environment.yml)

  Nextflow will activate the conda environment automatically per process.
  Conda must be on PATH (i.e. the base environment must be activated).

  Alternative: activate the environment yourself before running Nextflow:
    mamba activate genetic_qc
    nextflow run snp_array_qc/main.nf --bfile ...
  In that case, remove this config and don't use -profile conda.
================================================================================
*/

conda {
    enabled    = true
    useMamba   = true   // use mamba instead of conda for faster solves
    // cacheDir = '/path/to/shared/conda_envs'   // recommended for HPC
}

process {
    // Point all processes at the shared environment.yml.
    // Nextflow will create the environment once and reuse it.
    conda = "${projectDir}/containers/environment.yml"
}
