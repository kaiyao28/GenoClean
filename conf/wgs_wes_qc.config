/*
================================================================================
  wgs_wes_qc.config — WGS / WES Pipeline Defaults
================================================================================
  Override any of these values on the command line or in a params YAML file.
  This file is included automatically when running wgs_wes_qc/main.nf.
================================================================================
*/

params {

    // ── Input ─────────────────────────────────────────────────────────────────
    input_type       = "bam"   // fastq | bam | cram | vcf
    samplesheet      = null    // CSV: sample,file1[,file2]
    reference_fasta  = null    // path to reference FASTA (with .fai index)
    target_intervals = null    // capture BED file — required for WES mode
    gene_bed         = null    // optional BED for per-gene coverage
    mode             = "wes"   // wes | wgs

    // ── Phase-level switches ──────────────────────────────────────────────────
    run_variant_qc  = true
    run_sample_qc   = true
    chroms          = "1-22"    // chromosomes for per-chrom variant QC parallelism
    sample_qc_scope = "auto"   // auto | genome_wide | provisional | skip

    // ── Step switches ─────────────────────────────────────────────────────────
    run_fastqc                = true
    run_alignment_metrics     = true
    run_duplicate_metrics     = true
    run_coverage_qc           = true
    run_contamination         = true
    run_sex_check_wgs         = true
    run_variant_calling_qc    = true
    run_variant_filtering     = true
    run_genotype_filter       = true
    run_sample_variant_counts = true
    run_relatedness_wgs       = true
    run_ancestry_pca_wgs      = true
    run_final_report          = true

    // ── Coverage thresholds ───────────────────────────────────────────────────
    min_mean_depth_wgs      = 20
    min_mean_depth_wes      = 30
    min_target_20x_fraction = 0.80
    min_10x_fraction        = 0.90

    // ── Sample QC thresholds ──────────────────────────────────────────────────
    max_contamination    = 0.03
    max_duplication_rate = 0.20
    min_call_rate        = 0.95

    // ── Genotype-level thresholds ─────────────────────────────────────────────
    min_gq       = 20
    min_dp       = 10
    variant_qual = 30

    // ── GATK hard-filter thresholds — SNPs ───────────────────────────────────
    snp_qd               = 2.0
    snp_fs               = 60.0
    snp_mq               = 40.0
    snp_mqrank_sum       = -12.5
    snp_readpos_rank_sum = -8.0

    // ── GATK hard-filter thresholds — indels ─────────────────────────────────
    indel_qd               = 2.0
    indel_fs               = 200.0
    indel_readpos_rank_sum = -20.0

    // ── Filtering strategy ────────────────────────────────────────────────────
    variant_filter_method = "hard_filter"   // hard_filter | vqsr
    vqsr_hapmap           = null
    vqsr_omni             = null
    vqsr_1000g            = null
    vqsr_dbsnp            = null

    // ── Ancestry/relatedness ──────────────────────────────────────────────────
    reference_panel    = null
    pca_outlier_sd     = 6
    relatedness_pi_hat = 0.1875
    ld_window          = 200
    ld_step            = 50
    ld_r2              = 0.2
    n_pcs              = 20

    // ── PCA variant selection (WGS/WES specific, no equivalent in SNP array) ─
    // Common biallelic SNPs for PCA — rare variants and indels excluded.
    pca_maf                 = 0.05
    pca_variant_missingness = 0.01
    pca_use_snps_only       = true
    pca_autosomes_only      = true

    // ── Output ────────────────────────────────────────────────────────────────
    outdir            = "results/wgs_wes_qc"
    publish_dir_mode  = "copy"
    keep_intermediate = false
}
